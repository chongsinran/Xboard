APP_NAME=XBoard
APP_ENV=production
APP_KEY=base64:PZXk5vTuTinfeEVG5FpYv2l6WEhLsyvGpiWK7IgJJ60=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=xboard
DB_USERNAME=root
DB_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME=null
MAILGUN_DOMAIN=
MAILGUN_SECRET=

# google cloud storage
ENABLE_AUTO_BACKUP_AND_UPDATE=false
GOOGLE_CLOUD_KEY_FILE=config/googleCloudStorageKey.json
GOOGLE_CLOUD_STORAGE_BUCKET=

# Prevent reinstallation
INSTALLED=false

# Apple App Store Server API (In-App Purchase)
APPLE_IAP_BUNDLE_ID=com.bilink.bilinklink.pass
APPLE_IAP_ISSUER_ID=
APPLE_IAP_KEY_ID=
# Use either an escaped PEM value or a readable .p8 file path.
APPLE_IAP_PRIVATE_KEY=
APPLE_IAP_PRIVATE_KEY_PATH=
# Enable only when requests reach Xboard through your trusted Cloudflare proxy.
APPLE_IAP_TRUST_CF_COUNTRY_HEADER=false
